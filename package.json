{
  "name": "template-nuxt-nuxt-ui-drizzle-orm",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "nuxt build",
    "dev": "TMPDIR=/tmp nuxt dev",
    "generate": "nuxt generate",
    "preview": "nuxt preview",
    "prepare": "nuxt prepare && simple-git-hooks",
    "db:up": "docker compose up -d postgres",
    "db:down": "docker compose down",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:seed": "tsx scripts/seed/index.ts",
    "db:seed:demo": "tsx scripts/seed/index.ts --only=demo",
    "db:seed:system": "tsx scripts/seed/index.ts --only=system",
    "db:seed:reset": "tsx scripts/seed/index.ts --reset",
    "db:studio": "drizzle-kit studio",
    "screenshots": "tsx scripts/screenshot-pages.ts",
    "lint": "npm run lint:eslint && npm run lint:fallow",
    "lint:eslint": "eslint .",
    "lint:fallow": "fallow --skip health",
    "fallow:dead-code": "fallow dead-code",
    "fallow:dupes": "fallow dupes",
    "fallow:health": "fallow health --report-only",
    "fallow:production": "fallow --production --skip health",
    "fallow:fix:dry": "fallow fix --dry-run",
    "cdd:report": "tsx scripts/cdd-report.ts",
    "cdd:check": "tsx scripts/cdd-report.ts --fail-on-limit",
    "agent:check": "npm run lint && npm test && npm run cdd:check && npm run build",
    "ci": "npm run agent:check",
    "test": "vitest run"
  },
  "dependencies": {
    "@better-auth/drizzle-adapter": "1.6.14",
    "@nuxt/ui": "4.8.2",
    "better-auth": "1.6.14",
    "drizzle-orm": "^0.45.2",
    "nuxt": "^4.4.7",
    "pg": "8.21.0",
    "vue": "3.5.35",
    "vue-router": "5.1.0",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@nuxt/eslint": "^1.15.2",
    "@nuxt/test-utils": "4.0.3",
    "@playwright/test": "^1.59.1",
    "@types/pg": "8.20.0",
    "@vue/tsconfig": "0.9.1",
    "drizzle-kit": "0.31.10",
    "eslint": "10.4.1",
    "fallow": "2.89.0",
    "happy-dom": "20.10.2",
    "lint-staged": "17.0.7",
    "simple-git-hooks": "2.13.1",
    "tsx": "^4.22.4",
    "typescript": "6.0.3",
    "vitest": "^4.1.8",
    "vue-tsc": "3.3.3"
  },
  "simple-git-hooks": {
    "pre-commit": "npx lint-staged"
  },
  "lint-staged": {
    "*.(ts|js|vue)": "eslint --fix"
  }
}
