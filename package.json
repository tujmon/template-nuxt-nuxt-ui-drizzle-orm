    "drizzle-orm": "0.38.4",
    "nuxt": "3.21.7",
    "pg": "8.21.0",
    "vue": "3.5.35",
    "vue-router": "4.6.4",
    "zod": "3.25.76"
  },
  "devDependencies": {
    "@nuxt/eslint": "0.7.6",
    "@nuxt/test-utils": "3.23.0",
    "@types/pg": "8.20.0",
    "@vue/test-utils": "2.4.11",
    "@vue/tsconfig": "0.7.0",
    "drizzle-kit": "0.30.6",
    "eslint": "9.39.4",
    "fallow": "2.89.0",
    "happy-dom": "15.11.7",
    "lint-staged": "15.5.2",
    "simple-git-hooks": "2.13.1",
