{
  "name": "template-nuxt-nuxt-ui-drizzle-orm",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "nuxt build",
    "dev": "nuxt dev",
    "generate": "nuxt generate",
    "preview": "nuxt preview",
    "prepare": "nuxt prepare && simple-git-hooks",
    "db:up": "docker compose up -d postgres",
    "db:down": "docker compose down",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:seed": "tsx scripts/seed/index.ts",
    "db:seed:demo": "tsx scripts/seed/index.ts --only=demo",
    "db:seed:system": "tsx scripts/seed/index.ts --only=system",
    "db:seed:reset": "tsx scripts/seed/index.ts --reset",
    "db:studio": "drizzle-kit studio",
    "lint": "npm run lint:eslint && npm run lint:fallow",
    "lint:eslint": "eslint .",
    "lint:fallow": "fallow --skip health",
    "fallow:dead-code": "fallow dead-code",
    "fallow:dupes": "fallow dupes",
    "fallow:health": "fallow health --report-only",
    "fallow:production": "fallow --production --skip health",
    "fallow:fix:dry": "fallow fix --dry-run",
    "cdd:report": "tsx scripts/cdd-report.ts",
    "cdd:check": "tsx scripts/cdd-report.ts --fail-on-limit",
    "ci": "npm run lint && npm test && npm run build",
    "test": "vitest run"
  },
  "dependencies": {
    "@better-auth/drizzle-adapter": "1.6.14",
    "@nuxt/ui": "2.22.3",
    "better-auth": "1.6.14",
    "drizzle-orm": "^0.45.2",
    "nuxt": "3.21.7",
    "pg": "8.21.0",
    "vue": "3.5.35",
    "vue-router": "4.6.4",
    "zod": "3.25.76"
  },
  "devDependencies": {
    "@nuxt/eslint": "0.7.6",
    "@nuxt/test-utils": "3.23.0",
    "@types/pg": "8.20.0",
    "@vue/tsconfig": "0.7.0",
    "drizzle-kit": "0.30.6",
    "eslint": "9.39.4",
    "fallow": "2.89.0",
    "happy-dom": "15.11.7",
    "lint-staged": "15.5.2",
    "simple-git-hooks": "2.13.1",
    "tsx": "^4.22.4",
    "typescript": "5.9.3",
    "vitest": "2.1.9",
    "vue-tsc": "2.2.12"
  },
  "simple-git-hooks": {
    "pre-commit": "npx lint-staged"
  },
  "lint-staged": {
    "*.(ts|js|vue)": "eslint --fix"
  }
}
